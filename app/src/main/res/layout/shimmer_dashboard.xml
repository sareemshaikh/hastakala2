<?xml version="1.0" encoding="utf-8"?>
<!-- Shimmer skeleton shown while dashboard data loads -->
<com.facebook.shimmer.ShimmerFrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/shimmerDashboard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:shimmer_base_color="@color/shimmer_base"
    app:shimmer_highlight_color="@color/shimmer_highlight"
    app:shimmer_duration="1200">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- KPI row skeleton -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <View
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/shimmer_card_bg" />

            <View
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@drawable/shimmer_card_bg" />

        </LinearLayout>

        <!-- Second KPI row skeleton -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <View
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/shimmer_card_bg" />

            <View
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@drawable/shimmer_card_bg" />

        </LinearLayout>

        <!-- Recent sales skeleton rows -->
        <View
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/shimmer_card_bg" />

        <View
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/shimmer_card_bg" />

        <View
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="@drawable/shimmer_card_bg" />

    </LinearLayout>

</com.facebook.shimmer.ShimmerFrameLayout>
