<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/coordinatorRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/artisan_background">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp"
            android:gravity="center_vertical"
            android:minHeight="600dp">

            <!-- Brand header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginBottom="48dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏺"
                    android:textSize="56sp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hasta-Kala Shop"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/artisan_primary"
                    android:letterSpacing="-0.02"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your artisan business companion"
                    android:textSize="14sp"
                    android:textColor="@color/artisan_on_surface_variant" />

            </LinearLayout>

            <!-- Email field -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:hint="Email address"
                app:startIconDrawable="@android:drawable/ic_dialog_email"
                app:startIconTint="@color/artisan_primary"
                app:boxStrokeColor="@color/artisan_primary"
                app:hintTextColor="@color/artisan_primary"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textEmailAddress"
                    android:autofillHints="emailAddress" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Password field -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:hint="Password"
                app:passwordToggleEnabled="true"
                app:startIconDrawable="@android:drawable/ic_lock_lock"
                app:startIconTint="@color/artisan_primary"
                app:boxStrokeColor="@color/artisan_primary"
                app:hintTextColor="@color/artisan_primary"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:autofillHints="password" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Forgot password -->
            <TextView
                android:id="@+id/tvForgotPassword"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Forgot Password?"
                android:textColor="@color/artisan_primary"
                android:textSize="13sp"
                android:layout_gravity="end"
                android:padding="4dp"
                android:layout_marginBottom="28dp" />

            <!-- Login button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Sign In"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"
                app:cornerRadius="28dp"
                app:backgroundTint="@color/artisan_primary" />

            <!-- Progress -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:visibility="gone"
                android:layout_marginBottom="12dp"
                android:indeterminateTint="@color/artisan_primary" />

            <!-- Google Sign-In button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGoogleSignIn"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Sign in with Google"
                android:textSize="15sp"
                android:layout_marginBottom="12dp"
                app:cornerRadius="26dp"
                app:strokeColor="@color/artisan_primary"
                app:strokeWidth="1.5dp"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:drawableStart="@android:drawable/ic_menu_myplaces"
                android:drawablePadding="8dp"
                android:gravity="center" />

            <!-- Sign up link -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGoSignup"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Create Account"
                android:textSize="15sp"
                app:cornerRadius="26dp"
                app:strokeColor="@color/artisan_primary"
                app:strokeWidth="1.5dp"
                style="@style/Widget.Material3.Button.OutlinedButton" />

        </LinearLayout>
    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
