<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.HastaKalaShop" parent="Theme.AppCompat.Light.NoActionBar">
        <!-- Artisan warm color scheme -->
        <item name="colorPrimary">@color/artisan_primary</item>
        <item name="colorOnPrimary">@color/artisan_on_primary</item>

        <item name="colorSecondary">@color/artisan_secondary</item>
        <item name="colorOnSecondary">@color/artisan_on_secondary</item>

        <item name="colorSurface">@color/artisan_surface</item>
        <item name="colorOnSurface">@color/artisan_on_surface</item>
        <item name="colorOnSurfaceVariant">@color/artisan_on_surface_variant</item>

        <item name="android:colorBackground">@color/artisan_background</item>

        <item name="colorError">@color/artisan_error</item>
        <item name="colorOnError">@color/artisan_on_error</item>

        <item name="colorOutline">@color/artisan_outline</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/artisan_primary_dark</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Typography -->
        <item name="textAppearanceHeadlineLarge">@style/TextAppearance.HastaKala.HeadlineLarge</item>
        <item name="textAppearanceHeadlineMedium">@style/TextAppearance.HastaKala.HeadlineMedium</item>
        <item name="textAppearanceTitleLarge">@style/TextAppearance.HastaKala.TitleLarge</item>
        <item name="textAppearanceBodyLarge">@style/TextAppearance.HastaKala.BodyLarge</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.HastaKala.BodyMedium</item>
        <item name="textAppearanceLabelSmall">@style/TextAppearance.HastaKala.LabelSmall</item>

        <!-- Bottom navigation -->
        <item name="bottomNavigationStyle">@style/Widget.HastaKala.BottomNavigation</item>

        <!-- Card style -->
        <item name="materialCardViewStyle">@style/Widget.HastaKala.Card</item>

        <!-- FAB style -->
        <item name="floatingActionButtonStyle">@style/Widget.HastaKala.FAB</item>

        <!-- Window animations -->
        <item name="android:windowAnimationStyle">@style/WindowAnimation.HastaKala</item>
    </style>

    <!-- Typography -->
    <style name="TextAppearance.HastaKala.HeadlineLarge" parent="TextAppearance.AppCompat.Headline">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">32sp</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="TextAppearance.HastaKala.HeadlineMedium" parent="TextAppearance.AppCompat.Headline">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">24sp</item>
    </style>

    <style name="TextAppearance.HastaKala.TitleLarge" parent="TextAppearance.AppCompat.Title">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">20sp</item>
    </style>

    <style name="TextAppearance.HastaKala.BodyLarge" parent="TextAppearance.AppCompat.Body1">
        <item name="android:textSize">16sp</item>
        <item name="android:lineSpacingMultiplier">1.4</item>
    </style>

    <style name="TextAppearance.HastaKala.BodyMedium" parent="TextAppearance.AppCompat.Body2">
        <item name="android:textSize">14sp</item>
        <item name="android:lineSpacingMultiplier">1.3</item>
    </style>

    <style name="TextAppearance.HastaKala.LabelSmall" parent="TextAppearance.AppCompat.Caption">
        <item name="android:textSize">11sp</item>
        <item name="android:letterSpacing">0.04</item>
    </style>

    <!-- Bottom Navigation -->
    <style name="Widget.HastaKala.BottomNavigation" parent="Widget.Design.BottomNavigationView">
        <item name="android:background">@color/artisan_surface</item>
        <item name="itemIconTint">@color/bottom_nav_color</item>
        <item name="itemTextColor">@color/bottom_nav_color</item>
        <item name="elevation">8dp</item>
    </style>

    <!-- Card -->
    <style name="Widget.HastaKala.Card" parent="CardView">
        <item name="cardElevation">2dp</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardBackgroundColor">@color/artisan_surface</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <!-- FAB -->
    <style name="Widget.HastaKala.FAB" parent="Widget.Design.FloatingActionButton">
        <item name="backgroundTint">@color/artisan_primary</item>
        <item name="tint">@color/artisan_on_primary</item>
    </style>

    <!-- Window transitions -->
    <style name="WindowAnimation.HastaKala" parent="@android:style/Animation.Activity">
        <item name="android:activityOpenEnterAnimation">@anim/slide_in_right</item>
        <item name="android:activityOpenExitAnimation">@anim/slide_out_left</item>
        <item name="android:activityCloseEnterAnimation">@anim/slide_in_left</item>
        <item name="android:activityCloseExitAnimation">@anim/slide_out_right</item>
    </style>

    <!-- Dialog style -->
    <style name="Dialog.HastaKala" parent="Theme.AppCompat.Dialog">
        <item name="colorSurface">@color/artisan_surface</item>
    </style>

</resources>
